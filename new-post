#!/usr/bin/env bash
# Scaffold a new blog post: ./new-post "My Post Title"
# Creates posts/<slug>.md (with frontmatter + today's date) and an image folder
# at public/blog/<slug>/. See WRITING.md for the full guide.
set -euo pipefail
cd "$(dirname "$0")"

title="${*:-}"
if [[ -z "$title" ]]; then
  echo "usage: ./new-post \"My Post Title\"" >&2
  exit 1
fi

# Slug: lowercase, spaces/punctuation -> hyphens, trimmed.
slug="$(printf '%s' "$title" \
  | tr '[:upper:]' '[:lower:]' \
  | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//')"

file="posts/${slug}.md"
if [[ -e "$file" ]]; then
  echo "refusing to overwrite existing $file" >&2
  exit 1
fi

mkdir -p "posts" "public/blog/${slug}"
today="$(date +%Y-%m-%d)"

cat > "$file" <<EOF
---
title: ${title}
date: ${today}
description:
tags: []
draft: true
---

Write your post here.

Images go in \`public/blog/${slug}/\` and are referenced as
\`/blog/${slug}/name.svg\`. Attachments go in \`public/files/\`.
EOF

echo "created $file"
echo "created public/blog/${slug}/  (drop images here)"
echo
echo "next:"
echo "  \$EDITOR $file        # write it (remove 'draft: true' to publish)"
echo "  npm run dev           # preview locally"
echo "  ./d \"new post: ${slug}\"  # deploy"
